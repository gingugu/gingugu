    {
      "id": "b0000000-0000-4000-8000-000000000007",
      "namespace_id": "a1b2c3d4-0000-4000-8000-000000000002",
      "type": "decision",
      "title": "Slash commands only, no message scraping",
      "content": "Recipe-bot responds exclusively to slash commands. Reading channel messages requires privileged intents, a verification process, and privacy review — not worth it for a hobby bot. Slash commands cover every planned feature.",
      "confidence": "verified",
      "source": null,
