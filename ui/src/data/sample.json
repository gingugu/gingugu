    {
      "id": "b0000000-0000-4000-8000-000000000003",
      "namespace_id": "a1b2c3d4-0000-4000-8000-000000000001",
      "type": "decision",
      "title": "Postgres over TimescaleDB for v1",
      "content": "Decision: plain Postgres with a BRIN index on observed_at is enough for v1 volumes (~2M rows/month). TimescaleDB adds an extension dependency our managed host bills extra for. Revisit if retention grows past 12 months.",
      "confidence": "verified",
      "source": null,
      "created_at": "2026-04-05T15:00:00+00:00",
      "updated_at": "2026-04-05T15:00:00+00:00",
      "last_accessed": "2026-05-30T09:10:00+00:00",
      "last_confirmed": "2026-05-01T12:00:00+00:00",
      "access_count": 11,
      "metadata": null,
      "tags": ["postgres", "database", "v1-scope"]
    },
    {
      "id": "b0000000-0000-4000-8000-000000000004",
      "namespace_id": "a1b2c3d4-0000-4000-8000-000000000001",
      "type": "pattern",
      "title": "Retry with jitter on upstream fetches",
      "content": "All upstream API fetches use exponential backoff with full jitter (cap 60s, max 5 attempts). The TLE mirror rate-limits aggressively at the top of each hour; synchronized retries from multiple workers made it worse until jitter was added.",
      "confidence": "verified",
      "source": null,
      "created_at": "2026-04-08T11:20:00+00:00",
      "updated_at": "2026-04-08T11:20:00+00:00",
      "last_accessed": "2026-05-25T14:00:00+00:00",
      "last_confirmed": "2026-05-25T14:00:00+00:00",
      "access_count": 19,
      "metadata": null,
      "tags": ["retry", "backoff", "resilience"]
    },
    {
      "id": "b0000000-0000-4000-8000-000000000005",
      "namespace_id": "a1b2c3d4-0000-4000-8000-000000000001",
      "type": "fact",
      "title": "Ground station API caps at 100 req/min",
      "content": "The ground station partner API enforces 100 requests/minute per key. Exceeding it returns 429 with no Retry-After header. Budget calls accordingly in the scheduler.",
      "confidence": "inferred",
      "source": "observed behavior",
      "created_at": "2026-04-20T13:45:00+00:00",
      "updated_at": "2026-04-20T13:45:00+00:00",
      "last_accessed": "2026-05-10T08:30:00+00:00",
