    },
    {
      "id": "b0000000-0000-4000-8000-000000000010",
      "namespace_id": "a1b2c3d4-0000-4000-8000-000000000002",
      "type": "preference",
      "title": "Metric units in all stored recipes",
      "content": "Store all recipe quantities in metric; convert to imperial at render time based on the server locale setting. Mixed-unit storage caused double-conversion bugs twice.",
      "confidence": "verified",
