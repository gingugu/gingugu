    {
      "id": "b0000000-0000-4000-8000-000000000009",
      "namespace_id": "a1b2c3d4-0000-4000-8000-000000000002",
      "type": "pattern",
      "title": "Cache embeds, regenerate on edit only",
      "content": "Recipe embeds are expensive to build (image fetch + nutrition lookup). Cache the rendered embed keyed by recipe hash; invalidate only when the source recipe edits. Cut median response time from 2.1s to 180ms.",
      "confidence": "verified",
      "source": null,
      "created_at": "2026-05-02T16:00:00+00:00",
      "updated_at": "2026-05-02T16:00:00+00:00",
